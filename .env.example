# SMTP settings for contact form delivery.
# For Gmail, use smtp.gmail.com, port 465, and an app password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="buildwithwebsmith@gmail.com"
SMTP_PASS="your_gmail_app_password"

# Alias supported by the server if you prefer naming the Gmail secret explicitly.
GMAIL_APP_PASSWORD=""

# Recipient inbox for leads. Defaults to buildwithwebsmith@gmail.com if omitted.
LEAD_TO_EMAIL="buildwithwebsmith@gmail.com"

# Optional override for the From header.
LEAD_FROM_EMAIL="Websmith Leads <buildwithwebsmith@gmail.com>"

# Optional WhatsApp number used in links and diagnostics.
WHATSAPP_PHONE="918007006961"

# Optional local-only fallback for testing without SMTP.
# Set to "ethereal" only when you want a test inbox preview instead of real delivery.
CONTACT_FALLBACK_MODE=""
